{
  "name": "stealth-lightbeacon-node",
  "version": "3.0.9",
  "description": "TypeScript crawl orchestration, MCP tools, and multi-domain site auditing with security checks, SEO, AEO, GEO, and performance reporting",
  "main": "dist/index.js",
  "bin": {
    "stealth-lightbeacon": "dist/cli.js",
    "stealth-lightbeacon-mcp": "dist/mcp/stdio.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "prepack": "npm run build",
    "pack:dry": "npm pack --dry-run",
    "audit:signatures": "npm audit signatures",
    "pretest": "npm run build",
    "test": "node --test tests/*.test.js",
    "test:unit": "node --test tests/*.test.js",
    "test:unit:ci": "node --test $(ls tests/*.test.js | grep -Ev 'tests/(ontology|browser-pool|scraping|ssrf-dns-rebinding|mcp\\.integration)\\.test\\.js')",
    "test:ontology:local": "STEALTH_LIGHTBEACON_LOCAL_ONTOLOGY_TESTS=1 node --test tests/ontology.test.js",
    "test:mcp:contract": "node --test tests/mcp.test.js",
    "test:mcp:integration": "STEALTH_LIGHTBEACON_MCP_INTEGRATION_TESTS=1 node --test tests/mcp.integration.test.js",
    "coverage": "node --experimental-test-coverage --test tests/*.test.js",
    "coverage:ci": "node --experimental-test-coverage --test $(ls tests/*.test.js | grep -Ev 'tests/(ontology|browser-pool|scraping|ssrf-dns-rebinding|mcp\\.integration)\\.test\\.js')",
    "coverage:check": "node tools/check-coverage.js",
    "quality:typecheck": "npm run typecheck",
    "quality:unit": "npm run test:unit:ci",
    "quality:mcp:contract": "npm run test:mcp:contract",
    "quality:coverage": "COVERAGE_MODE=ci npm run coverage:check",
    "quality:integration:mcp": "npm run test:mcp:integration",
    "quality:check": "npm run quality:typecheck && npm run quality:unit && npm run quality:mcp:contract && npm run quality:coverage",
    "test:watch": "node --test --watch tests/*.test.js",
    "start": "npm run build && node dist/cli.js",
    "mcp": "npm run build && node dist/mcp/stdio.js"
  },
  "keywords": [
    "drupal",
    "seo",
    "audit",
    "performance",
    "aeo",
    "geo",
    "crawler",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "readme.md",
    "LICENSE",
    "SECURITY.md",
    ".env.example"
  ],
  "dependencies": {
    "@duckdb/node-api": "^1.5.3-r.1",
    "@lancedb/lancedb": "^0.29.0",
    "cheerio": "^1.0.0-rc.12",
    "commander": "^11.1.0",
    "handlebars": "^4.7.8",
    "lighthouse": "^13.3.0",
    "ora": "^7.0.1",
    "playwright-core": "^1.55.0",
    "robots-parser": "^3.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
